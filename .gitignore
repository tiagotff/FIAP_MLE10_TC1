.ruff_cache/
.mypy_cache/

# ===== MLflow =====
mlruns/
mlartifacts/
mlflow.db

# ===== Modelos e artefatos pesados =====
models/*.pkl
models/*.pt
models/*.pth
models/*.joblib
!models/.gitkeep
# model_metadata.json é pequeno, legível e documenta o modelo treinado
# (métricas, parâmetros, versão) — versionado propositalmente.
!models/model_metadata.json

# ===== Dados =====
# Versionamos apenas o dataset bruto de referência (pequeno, público).
# Dados processados/intermediários não são versionados.
data/processed/*
!data/processed/.gitkeep
data/interim/*
!data/interim/.gitkeep

# ===== Variáveis de ambiente / segredos =====
.env
.env.*
*.pem
*.key

# ===== Credenciais de nuvem (GCP/AWS/Azure) — NUNCA versionar =====
# Chaves de service account do GCP, sempre terminam em .json e contêm
# "private_key" — bloqueadas por padrão de nome e por extensão completa
# em pastas de credenciais comuns.
*-key.json
*-credentials.json
*service-account*.json
gcp-key*.json
.gcloud/
credentials/
secrets/
*.credentials

# ===== IDEs =====
.vscode/
.idea/
*.swp
*.swo

# ===== OS =====
.DS_Store
Thumbs.db

# ===== Logs =====
*.log
logs/

# ===== Outros =====
.ipynb_checkpoints
*.bak
